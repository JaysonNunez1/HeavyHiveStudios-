# ============================================
# Heavy Hive Studios - Beat Checkout Service
# Environment Variables Configuration
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=production

# ============================================
# STRIPE CONFIGURATION
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# 
# Secret Key: Found in Developers > API Keys > Secret key
# - Use "sk_test_..." for testing
# - Use "sk_live_..." for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook Secret: Found in Developers > Webhooks > Select endpoint > Signing secret
# - Create a webhook endpoint pointing to: https://yourdomain.com/api/webhook/stripe
# - Select the event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ============================================
# AWS S3 CONFIGURATION
# ============================================
# Get these from: AWS Console > IAM > Users > Security Credentials
#
# 1. Create an IAM user with S3 access
# 2. Attach policy: AmazonS3ReadOnlyAccess (or custom policy for specific bucket)
# 3. Generate Access Keys
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# S3 Bucket where your beat files are stored
# Example structure: s3://heavyhive-beats/beats/beat-001.wav
S3_BUCKET_NAME=heavyhive-beats

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# For Gmail:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for "Mail"
# 4. Use that 16-character password below (not your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=heavystudios@gmail.com
SMTP_PASS=your_gmail_app_password_here

# From address for outgoing emails
EMAIL_FROM="Heavy Hive Studios <heavystudios@gmail.com>"

# ============================================
# OPTIONAL: Custom Configuration
# ============================================
# How long the download link should be valid (in seconds)
# Default: 86400 (24 hours)
DOWNLOAD_LINK_EXPIRY=86400
